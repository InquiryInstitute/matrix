# Copy to `.env` and adjust. `.env` is gitignored.

# Synapse admin (Element → Settings → Help & About → Access token). Used by:
#   scripts/reset-custodian-password.sh, scripts/make-custodian-admin.sh
# ADMIN_ACCESS_TOKEN=

# Custodian bot Matrix password (overrides password in matrix-bot-credentials.json when set). Used by:
#   scripts/check-custodian-login.sh, scripts/start-custodian-bot.sh, validate-board-communication.py
# CUSTODIAN_PASSWORD=

# Supabase → Synapse OIDC (scripts/configure-matrix-oidc.sh)
# SUPABASE_PROJECT_REF=
# OAuth App client ID (Authentication → OAuth Apps → public client). Required for OAuth 2.1 IdP; do not use anon JWT here.
# SUPABASE_OIDC_CLIENT_ID=
# Legacy only (may 400 on /oauth/authorize if the project uses OAuth 2.1):
# SUPABASE_ANON_KEY=
# Public Client-Server API URL (Synapse public_baseurl). OIDC redirect_uri uses this host — must match Supabase OAuth App.
# Must match Synapse server_name until DB migration (see CASTALIA_ELEMENT_SUPABASE.md).
# SYNAPSE_PUBLIC_BASEURL=https://matrix.inquiry.institute
# MATRIX_SERVER_URL=https://matrix.inquiry.institute
# Local dev: MATRIX_SERVER_URL=http://localhost:8008
